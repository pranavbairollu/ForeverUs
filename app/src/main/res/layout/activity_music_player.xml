<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_music_player"
    android:keepScreenOn="true">

    <!-- Visualizer (Background Ambient) -->
    <com.example.foreverus.MusicVisualizerView
        android:id="@+id/visualizerView"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:alpha="0.15"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Player Container (Enforces 16:9 Ratio & Stability) -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/playerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="80dp"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
            android:id="@+id/youtubePlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:enableAutomaticInitialization="false" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fallback Web Player -->
    <WebView
        android:id="@+id/fallbackWebView"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="80dp"
        android:visibility="gone"
        app:layout_constraintVertical_bias="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/songInfoContainer"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Song Info -->
    <LinearLayout
        android:id="@+id/songInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/playerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#20FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/playerSongTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    tools:text="Song Title"/>

                <TextView
                    android:id="@+id/playerSongArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#EEFFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:gravity="center"
                    tools:text="Artist Name"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/statusMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/color_danger"
            android:visibility="gone"
            android:gravity="center"
            tools:text="No internet connection"/>

        <!-- Transport Controls -->
        <LinearLayout
            android:id="@+id/controlsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="48dp">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_baseline_shuffle_24"
                android:contentDescription="Shuffle"
                android:tint="@android:color/white"
                android:padding="14dp"
                android:alpha="0.5"/>

            <View android:layout_width="24dp" android:layout_height="0dp"/>

            <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Previous Song"
                android:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:padding="18dp"/>

            <View android:layout_width="16dp" android:layout_height="0dp"/>
            
            <ImageButton
                 android:id="@+id/btnShare"
                 android:layout_width="72dp"
                 android:layout_height="72dp"
                 android:background="?attr/selectableItemBackgroundBorderless"
                 android:src="@drawable/ic_share"
                 android:contentDescription="Share Song"
                 android:tint="@android:color/white"
                 android:scaleType="fitCenter"
                 android:padding="18dp"/>

            <View android:layout_width="16dp" android:layout_height="0dp"/>

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Next Song"
                android:tint="@android:color/white"
                android:scaleType="fitCenter"
                android:padding="18dp"/>

            <View android:layout_width="24dp" android:layout_height="0dp"/>

            <ImageButton
                android:id="@+id/btnLoop"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_baseline_repeat_24"
                android:contentDescription="Loop"
                android:tint="@android:color/white"
                android:padding="14dp"
                android:alpha="0.5"/>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnOpenYoutube"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play Video"
        android:visibility="gone"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/color_danger"
        android:textColor="@android:color/white"
        app:icon="@drawable/ic_baseline_arrow_back_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Scrim for Button Visibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/scrim_top"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_baseline_arrow_back_24"
        android:contentDescription="@string/cd_close_player"
        android:tint="@android:color/white"
        android:elevation="20dp"
        android:translationZ="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



</androidx.constraintlayout.widget.ConstraintLayout>
