<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_polaroid_dark"
    tools:context=".PolaroidMakerActivity">

    <!-- Toolbar area -->
    <LinearLayout
        android:id="@+id/toolbarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Polaroid Maker"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageView
            android:id="@+id/btnViewGallery"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="My Polaroids"
            android:padding="10dp"
            android:src="@drawable/ic_baseline_photo_library_24"
            app:tint="@android:color/white"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/btnSave"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save Polaroid"
            android:padding="10dp"
            android:src="@drawable/ic_baseline_save_24"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- Polaroid Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/polaroidContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="32dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="2dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toTopOf="@+id/enhancementsLayout"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbarContainer">

        <!-- Frame Background Layer -->
        <ImageView
            android:id="@+id/imgFrameBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:color/white" 
            android:contentDescription="Frame Texture" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="48dp">

            <!-- Photo Area (Square-ish) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#F8F8F8"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgPolaroidPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_image" 
                    android:contentDescription="Polaroid Photo" />
                
                <ImageView
                    android:id="@+id/imgTextureOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Texture Overlay" />
                
                <TextView
                    android:id="@+id/txtDateStamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:padding="8dp"
                    android:text="25 12 18"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-light"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:shadowColor="#80000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="2" />
                
                <!-- Overlay for 'Develop' animation -->
                <View
                    android:id="@+id/viewDevelopOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#D0D0D0"
                    android:visibility="gone"/>

            </androidx.cardview.widget.CardView>

            <!-- Caption Area -->
            <EditText
                android:id="@+id/editCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@null"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:hint="Write a memory..."
                android:textColorHint="#A0A0A0"
                android:lines="2"
                android:maxLines="2"
                android:ellipsize="end"
                android:inputType="textCapSentences|textMultiLine"
                android:textColor="#333333"
                android:textSize="14sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
    
    <!-- Enhancements Controls -->
    <LinearLayout
        android:id="@+id/enhancementsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/fabShare"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@android:color/white"/>
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFrame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frame"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@android:color/white"/>
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEffect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Effect"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@android:color/white"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@android:color/white"/>
            
    </LinearLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTakePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="Camera"
            app:icon="@drawable/ic_camera"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@android:color/white"
            app:strokeColor="@android:color/white"
            app:iconTint="@android:color/white"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickGallery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gallery"
            app:icon="@drawable/ic_baseline_photo_library_24"
            style="@style/Widget.MaterialComponents.Button"
            app:backgroundTint="@color/midnight_sky_accent"/>


    </LinearLayout>
    
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabShare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Share Polaroid"
        android:src="@drawable/ic_share"
        app:layout_constraintBottom_toTopOf="@+id/controlsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/midnight_sky_accent" 
        app:tint="@android:color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
