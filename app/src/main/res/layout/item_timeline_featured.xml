<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    app:rippleColor="?attr/colorControlHighlight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Minimalist and Airy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <!-- Title with clear hierarchy -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="On This Day ❤️"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <!-- Subtle secondary info -->
            <TextView
                android:id="@+id/featuredDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?android:textColorSecondary"
                android:background="@drawable/bg_capsule_outline" 
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                tools:text="1 Year Ago" />
            <!-- Note: bg_capsule_outline is assumed, or just remove background if unnecessary. Using simple padding for clean look. -->
            
        </LinearLayout>

        <!-- Divider (Optional, kept subtle if needed? No, let's keep it fluid) -->

        <!-- Image Content (Full Bleed/Cropped) -->
        <ImageView
            android:id="@+id/featuredImageView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:src="@tools:sample/backgrounds/scenic"
            tools:visibility="visible" />

        <!-- Text Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/featuredTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold"
                tools:text="Our Trip to Paris" />

            <TextView
                android:id="@+id/featuredSnippet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="3"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:textColorSecondary"
                android:lineSpacingExtra="4dp"
                tools:text="Ideally, this snippet shows the beginning of a story or letter content to give a preview." />
            
            <!-- More Matches Chip/Indication -->
            <TextView
                android:id="@+id/moreMatchesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:text="+ 2 more memories"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                app:drawableStartCompat="@drawable/ic_baseline_photo_library_24"
                android:drawablePadding="4dp"
                tools:visibility="visible" 
                tools:drawableStart="@drawable/ic_baseline_photo_library_24"/> 
                <!-- Using photo_library or similar generic icon if available. If broken, removed drawable in code logic or rely on text only. -->

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
