        android:label="@string/title_songs"
        tools:layout="@layout/fragment_songs" />
    <fragment
        android:id="@+id/settings"
        android:name="com.example.foreverus.SettingsFragment"
        android:label="@string/title_settings"
        tools:layout="@layout/fragment_settings" />
    <fragment
        android:id="@+id/menu_more"
        android:name="com.example.foreverus.MenuFragment"
        android:label="@string/menu_more"
        tools:layout="@layout/fragment_menu" />
    
    <fragment
        android:id="@+id/adventure_board"
        android:name="com.example.foreverus.AdventureBoardFragment"
