<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/story">

    <fragment
        android:id="@+id/timeline"
        android:name="com.example.foreverus.TimelineFragment"
        android:label="@string/title_timeline"
        tools:layout="@layout/fragment_timeline" />
    <fragment
        android:id="@+id/memories"
        android:name="com.example.foreverus.MemoriesFragment"
        android:label="@string/title_memories"
