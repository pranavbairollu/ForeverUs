    <fragment
        android:id="@+id/story"
        android:name="com.example.foreverus.StoryFragment"
        android:label="@string/title_story"
        tools:layout="@layout/fragment_story" />
    <fragment
        android:id="@+id/letters"
        android:name="com.example.foreverus.LettersFragment"
        android:label="@string/title_letters"
