<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ForeverUs" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Typography Mapping -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.ForeverUs.DisplayLarge</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.ForeverUs.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.ForeverUs.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.ForeverUs.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.ForeverUs.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.ForeverUs.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.ForeverUs.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.ForeverUs.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.ForeverUs.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.ForeverUs.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.ForeverUs.LabelLarge</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.ForeverUs.LabelSmall</item>

        <!-- Shape: Soft, rounded corners -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.ForeverUs.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.ForeverUs.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.ForeverUs.Large</item>
        
        <!-- Common Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorError">@color/error_text</item>
        
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorPrimaryContainer">@color/primary_container_light</item>

        <!-- Semantic Mappings (Light) -->
        <item name="colorAiHighlight">@color/color_ai_highlight_light</item>
        <item name="colorGhostText">@color/color_ghost_text_light</item>
        <item name="colorDiffInsert">@color/color_diff_insert_light</item>
        <item name="colorDiffDelete">@color/color_diff_delete_light</item>
        
        <item name="colorEditorText">@color/editor_system_text_light</item>
        <item name="colorEditorBackground">@color/editor_system_bg_light</item>
        <item name="colorEditorHint">@color/editor_system_hint_light</item>
        <item name="colorEditorCursor">@color/editor_system_cursor_light</item>
        <item name="colorEditorSelection">@color/editor_system_selection_light</item>
        <item name="colorEditorSelectionHandle">@color/pink_dream_accent</item>
        
        <item name="colorLetterText">@color/letter_text_light</item>
        <item name="colorLetterHint">@color/letter_hint_light</item>
        <item name="colorLetterPaper">@color/letter_paper_light</item>

        <!-- Transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimation.Slide</item>
    </style>

    <style name="WindowAnimation.Slide" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- Shape Styles -->
    <style name="ShapeAppearance.ForeverUs.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.ForeverUs.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.ForeverUs.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Theme.ForeverUs" parent="Base.Theme.ForeverUs" />

    <style name="Theme.ForeverUs.NoActionBar" parent="Theme.ForeverUs">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/pink_dream_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.ForeverUs</item>
    </style>

    <!-- Pink Dream Theme -->
    <style name="Theme.ForeverUs.PinkDream" parent="Base.Theme.ForeverUs">
        <item name="colorPrimary">@color/pink_dream_primary</item>
        <item name="colorPrimaryDark">@color/pink_dream_primary_dark</item>
        <item name="colorAccent">@color/pink_dream_accent</item>
        <item name="android:windowBackground">@color/pink_dream_background</item>
        <item name="colorSecondary">@color/pink_dream_accent</item> 
    </style>

    <!-- Midnight Sky Theme -->
    <style name="Theme.ForeverUs.MidnightSky" parent="Base.Theme.ForeverUs">
        <item name="colorPrimary">@color/midnight_sky_primary</item>
        <item name="colorPrimaryDark">@color/midnight_sky_primary_dark</item>
        <item name="colorAccent">@color/midnight_sky_accent</item>
        <item name="android:windowBackground">@color/midnight_sky_background</item>
        <item name="colorSecondary">@color/midnight_sky_accent</item>
    </style>

    <!-- Rose Gold Theme -->
    <style name="Theme.ForeverUs.RoseGold" parent="Base.Theme.ForeverUs">
        <item name="colorPrimary">@color/rose_gold_primary</item>
        <item name="colorPrimaryDark">@color/rose_gold_primary_dark</item>
        <item name="colorAccent">@color/rose_gold_accent</item>
        <item name="android:windowBackground">@color/rose_gold_background</item>
        <item name="colorSecondary">@color/rose_gold_accent</item>
    </style>
    
    <!-- Widget / Card Styles -->
    <style name="Widget.ForeverUs.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.ForeverUs.Medium</item>
    </style>
</resources>